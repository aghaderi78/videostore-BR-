SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.replit.dev,.repl.co,.replit.app

# ── پیامک کاوه‌نگار ──────────────────────────────────────────
# ثبت‌نام رایگان: https://panel.kavenegar.com
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_SENDER=10004346

# ── پیامک SMS.ir (جایگزین کاوه‌نگار) ────────────────────────
# ثبت‌نام: https://app.sms.ir
SMSIR_API_KEY=your-smsir-api-key
SMSIR_LINE_NUMBER=30007732XXXXXX

# ── درگاه زرین‌پال ───────────────────────────────────────────
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=True

OTP_EXPIRE_MINUTES=5

# ── تنظیمات اختیاری (پروداکشن) ──────────────────────────────
# USE_SQLITE=False
